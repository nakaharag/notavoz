# Authentication
AUTH_USER=admin
AUTH_PASSWORD=your-secure-password-here
JWT_SECRET=your-random-jwt-secret-key-here

# OpenAI API (for Whisper speech-to-text)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API (for Claude AI processing)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Frontend API URL (set at build time)
REACT_APP_API_URL=https://api.notavoz.com.br

# Backend CORS (comma-separated origins)
CORS_ORIGIN=https://notavoz.com.br,https://www.notavoz.com.br
